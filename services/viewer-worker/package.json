{
  "name": "@yrdsl/viewer-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker on yrdsl.app/* that overlays the GH Pages landing with the published-sale viewer at /{user}/{slug}.",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}

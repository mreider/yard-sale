{
  "name": "@yrdsl/cleanup-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Scheduled Worker. Nightly purge of expired confirmation/reset tokens, stale sessions, hard-deleted sales, and expired slug redirects.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .wrangler dist .turbo"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}

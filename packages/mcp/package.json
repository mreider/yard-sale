{
  "name": "@yrdsl/mcp",
  "version": "0.5.0",
  "description": "MCP server for yrdsl.app. Talks to either the hosted API (api.yrdsl.app) or a local self-hosted repo. Lets Claude add, edit, and reserve items on a digital yard sale.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "bin": {
    "yrdsl-mcp": "./dist/index.js",
    "mcp": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "yrdsl",
    "yard-sale",
    "claude",
    "anthropic",
    "model-context-protocol",
    "ai"
  ],
  "author": {
    "name": "Matt Reider",
    "email": "mreider@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KuvopLLC/yrdsl.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://yrdsl.app",
  "bugs": {
    "url": "https://github.com/KuvopLLC/yrdsl/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

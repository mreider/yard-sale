# Copy to .dev.vars for local development.
# .dev.vars is gitignored.

# Generate with: openssl rand -hex 32
SESSION_SIGNING_KEY=change-me-to-a-32-byte-hex-string-please

# Localhost origins only apply in dev. Production uses wrangler.toml's [vars].
ALLOWED_ORIGINS=https://yrdsl.app,http://localhost:5173,http://localhost:4173

# Leave unset for the stub mailer (logs to console, returns confirmation
# URLs directly in API responses for local testing).
# RESEND_API_KEY=re_xxxxxxx

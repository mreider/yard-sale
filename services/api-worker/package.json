{
  "name": "@yrdsl/api-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker: auth, accounts, tokens, profile, billing (M1 scope: auth/profile/tokens).",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .wrangler dist .turbo"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@noble/hashes": "^1.6.1",
    "@yrdsl/core": "workspace:*",
    "fflate": "^0.8.2",
    "hono": "^4.6.13",
    "nanoid": "^5.0.9",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}

{
  "name": "@yrdsl/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared zod schemas and TypeScript types for the yrdsl.app JSON shapes (SaleSite, SaleItem).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./validation": "./src/validation/index.ts",
    "./schemas": "./src/schemas/index.ts"
  },
  "files": ["src", "README.md", "LICENSE"],
  "scripts": {
    "build": "echo 'core is consumed as source' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KuvopLLC/yrdsl.git",
    "directory": "packages/core"
  },
  "homepage": "https://yrdsl.app",
  "bugs": {
    "url": "https://github.com/KuvopLLC/yrdsl/issues"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
